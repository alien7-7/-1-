#include <bits/stdc++.h>
using namespace std;

int main() {
    long long n, omega;
    cin >> n >> omega;
    vector<long long> w(n);
    vector<int> idx(n);
    for (int i = 0; i < n; i++) {
        cin >> w[i];
        idx[i] = i + 1;
    }
    
    sort(idx.begin(), idx.end(), [&](int a, int b) {
        return w[a - 1] < w[b - 1];
    });
    
    long long mass = omega;
    vector<int> order;
    for (int i = 0; i < n; i++) {
        long long val = w[idx[i] - 1];
        if (val < mass) {
            mass += val;
            order.push_back(idx[i]);
        } else {
            cout << "NO" << endl;
            return 0;
        }
    }
    
    cout << "YES" << "\n";
    for (int i = 0; i < n; i++) {
        cout << order[i] << (i + 1 < n ? ' ' : '\n');
    }
    
    return 0;
}
