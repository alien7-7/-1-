#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int N;
    cin >> N;
    
    vector<int> dp(N+1, 0);
    dp[1] = 0;
    
    for (int i = 2; i <= N; i++) {
        int best = dp[i-1];
        if (i % 2 == 0) best = min(best, dp[i/2]);
        if (i % 3 == 0) best = min(best, dp[i/3]);
        dp[i] = best + i;
    }
    
    cout << dp[N] << endl;
    
    return 0;
}
